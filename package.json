{
	"name": "gopro-webui",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"start": "npm run frontend && npm run backend",
		"stop": "pm2 stop all",
		"restart": "pm2 restart all",
		"delete": "pm2 delete all",
		"monit": "pm2 monit",
		"frontend": "pm2 start build --name frontend --log logs/frontend.log",
		"backend": "pm2 start backend/main.py --name backend --log logs/backend.log",

		"dev": "pm2 start backend/main.py --watch && vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.66.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"daisyui": "^5.5.20",
		"eslint": "^10.2.0",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"pm2": "^7.0.1"
	}
}
